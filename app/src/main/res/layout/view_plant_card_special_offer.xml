<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="192dp"
        android:layout_height="260dp"
        app:cardBackgroundColor="@color/dark_teal"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/bgShape"
                android:layout_width="130dp"
                android:layout_height="160dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/bg_plant_image_shape" />

            <ImageView
                android:id="@+id/btnFavorite"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_margin="14dp"
                android:contentDescription="Favorite"
                android:padding="4dp"
                android:src="@drawable/ic_favorite"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/imgPlant"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_alignParentTop="true"
                android:layout_margin="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/img_cactus" />

            <TextView
                android:id="@+id/txtName"
                android:layout_width="112dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/bgShape"
                android:layout_alignParentStart="true"
                android:layout_marginHorizontal="14dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Cactus"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgCategory"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_below="@id/txtName"
                android:layout_alignParentStart="true"
                android:layout_marginStart="14dp"
                android:layout_marginTop="8dp"
                android:contentDescription="Plant category"
                android:src="@drawable/ic_indoor_plant" />

            <TextView
                android:id="@+id/txtCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/imgCategory"
                android:layout_marginStart="4dp"
                android:layout_toEndOf="@id/imgCategory"
                android:text="Indoor Plant"
                android:textColor="@color/light_teal"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/imgStar"
                android:layout_width="19dp"
                android:layout_height="19dp"
                android:layout_alignTop="@id/txtCategory"
                android:layout_toStartOf="@id/rating"
                android:src="@drawable/ic_star"
                app:tint="@color/yellow" />

            <TextView
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/txtCategory"
                android:layout_toStartOf="@id/number_of_rating"
                android:text="5.0"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/number_of_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@id/txtCategory"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="14dp"
                android:text="(39)"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtNewPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="14dp"
                android:text="$5.75"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnAdd"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="14dp"
                android:background="@drawable/bg_circle_teal"
                android:contentDescription="Add"
                android:padding="10dp"
                android:src="@drawable/ic_add"
                app:tint="@android:color/white" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

</merge>