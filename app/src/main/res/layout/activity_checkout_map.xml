<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.gms.maps.MapView
        android:id="@+id/liveMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomPanel" />

    <ImageView
        android:id="@+id/mapCenterPin"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_centerInParent="true"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_location_foreground"
        app:tint="@color/teal"
        android:contentDescription="Selected Location Pin" />

    <RelativeLayout
        android:id="@+id/topHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="44dp"
        android:paddingHorizontal="16dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back_ios_foreground"
            android:contentDescription="Back"
            app:tint="#111111" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Checkout"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="34dp"
        android:layout_alignParentBottom="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_search_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="40dp">

            <ImageView
                android:id="@+id/iconSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_search"
                app:tint="#A0A0A0"
                android:contentDescription="Search Icon" />

            <EditText
                android:id="@+id/etSearchAddress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/iconSearch"
                android:layout_toStartOf="@+id/btnClearText"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@android:color/transparent"
                android:hint="Enter your address"
                android:textColorHint="#C5C5C5"
                android:textColor="#111111"
                android:textSize="16sp"
                android:inputType="textPostalAddress"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/btnClearText"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_close_foreground"
                app:tint="#A0A0A0"
                android:contentDescription="Clear Text" />
        </RelativeLayout>

        <Button
            android:id="@+id/btnConfirmAddress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_action_button"
            android:text="Add address details"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/teal" />

    </LinearLayout>

</RelativeLayout>