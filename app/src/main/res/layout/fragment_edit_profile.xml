<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomSaveContainer"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/btnBack"
                    android:contentDescription="Back"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_arrow_back_ios_foreground"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_centerHorizontal="true" />
            </RelativeLayout>

            <FrameLayout
                android:id="@+id/profileImageContainer"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:layout_width="120dp"
                android:layout_height="120dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/profile"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="#27B1AF"
                    app:strokeWidth="1dp" />

                <ImageView
                    android:id="@+id/btnChangeImage"
                    android:contentDescription="Change image"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_camera"
                    android:layout_gravity="bottom|end" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="24dp" />

            <EditText
                android:id="@+id/edtName"
                android:inputType="textPersonName"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:hint="Name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/edtEmail"
                android:inputType="textEmailAddress"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/ic_email_foreground"
                android:drawablePadding="10dp"
                android:padding="12dp"
                android:hint="Email" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/ic_lock"
                android:padding="12dp"
                android:inputType="textPassword"
                android:hint="Leave blank to keep old password" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/ic_lock"
                android:padding="12dp"
                android:inputType="textPassword"
                android:hint="Confirm New Password" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomSaveContainer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_alignParentBottom="true"
        android:paddingVertical="20dp"
        android:paddingHorizontal="40dp"
        android:background="#D9D9D9">

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Save"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_menu_profile" />
    </LinearLayout>

</RelativeLayout>