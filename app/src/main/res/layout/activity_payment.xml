<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- Top Bar -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back_ios_foreground"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="@string/back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/payment"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginEnd="40dp"/>

    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/choose_a_payment_method"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"/>

    <!-- ABA Pay Option -->
    <RadioGroup
        android:id="@+id/paymentRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- ABA Pay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/payment_option_bg"
            android:layout_marginBottom="12dp"
            android:padding="16dp">

            <RadioButton
                android:id="@+id/radioAbaPay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#3BBFBF"
                android:layout_marginEnd="12dp"
                android:contentDescription="@null"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="100dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_aba_pay"
                android:scaleType="centerCrop"
                android:contentDescription="@string/aba_pay"
                app:shapeAppearanceOverlay="@style/RoundedImage"/>

        </LinearLayout>

        <!-- Wing Bank -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/payment_option_bg"
            android:layout_marginBottom="12dp"
            android:padding="16dp">

            <RadioButton
                android:id="@+id/radioWingBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#3BBFBF"
                android:layout_marginEnd="12dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="100dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_wing_bank"
                android:scaleType="centerCrop"
                android:contentDescription="@string/wing_bank"
                app:shapeAppearanceOverlay="@style/RoundedImage"/>

        </LinearLayout>

        <!-- Credit or Debit Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/payment_option_bg"
            android:layout_marginBottom="12dp"
            android:padding="16dp">

            <RadioButton
                android:id="@+id/radioCreditDebit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#3BBFBF"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/credit_or_debit_card"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_visa"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/visa"
                        android:layout_marginEnd="6dp"/>

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_mastercard"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/mastercard"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </RadioGroup>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <!-- Pay Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/pay"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3BBFBF"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="32dp"
        app:cornerRadius="28dp"/>

</LinearLayout>