<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrow_back_ios_foreground"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="40dp"
        android:layout_height="40dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Cart"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBack"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"/>


    <!-- Scrollable Cart Items -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dividerSummary"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <!-- Cart Item 1: Cactus -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCactus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#2ABFBF"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imgCactus"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_cactus"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:src="@tools:sample/avatars" />

                    <TextView
                        android:id="@+id/tvCactusName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Cactus"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgCactus"
                        app:layout_constraintTop_toTopOf="@id/imgCactus"
                        app:layout_constraintEnd_toStartOf="@id/btnDeleteCactus" />

                    <TextView
                        android:id="@+id/tvCactusPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 5.75"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/imgCactus"
                        app:layout_constraintTop_toBottomOf="@id/tvCactusName" />

                    <ImageButton
                        android:id="@+id/btnDeleteCactus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        app:tint="#2ABFBF"
                        android:contentDescription="Delete Cactus"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Quantity Controls -->
                    <ImageButton
                        android:id="@+id/btnCactusMinus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_gray"
                        android:src="@drawable/ic_minus"
                        app:tint="#888888"
                        android:contentDescription="Decrease quantity"
                        app:layout_constraintEnd_toStartOf="@id/tvCactusQty"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvCactusQty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginHorizontal="8dp"
                        app:layout_constraintEnd_toStartOf="@id/btnCactusPlus"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageButton
                        android:id="@+id/btnCactusPlus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_teal"
                        android:src="@drawable/ic_plus"
                        android:contentDescription="Increase quantity"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:tint="#FFFFFF" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cart Item 2: Spider Plant -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpiderPlant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#2ABFBF"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imgSpiderPlant"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_spider_plant"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:src="@tools:sample/avatars" />

                    <TextView
                        android:id="@+id/tvSpiderPlantName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Spider plant"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgSpiderPlant"
                        app:layout_constraintTop_toTopOf="@id/imgSpiderPlant"
                        app:layout_constraintEnd_toStartOf="@id/btnDeleteSpider" />

                    <TextView
                        android:id="@+id/tvSpiderPlantPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 9.30"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/imgSpiderPlant"
                        app:layout_constraintTop_toBottomOf="@id/tvSpiderPlantName" />

                    <ImageButton
                        android:id="@+id/btnDeleteSpider"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        app:tint="#2ABFBF"
                        android:contentDescription="Delete Spider Plant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton
                        android:id="@+id/btnSpiderMinus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_gray"
                        android:src="@drawable/ic_minus"
                        app:tint="#888888"
                        android:contentDescription="Decrease quantity"
                        app:layout_constraintEnd_toStartOf="@id/tvSpiderQty"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvSpiderQty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginHorizontal="8dp"
                        app:layout_constraintEnd_toStartOf="@id/btnSpiderPlus"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageButton
                        android:id="@+id/btnSpiderPlus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_teal"
                        android:src="@drawable/ic_plus"
                        app:tint="#FFFFFF"
                        android:contentDescription="Increase quantity"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cart Item 3: Snake Plant -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSnakePlant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#2ABFBF"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/imgSnakePlant"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_snake_plant"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        tools:src="@tools:sample/avatars" />

                    <TextView
                        android:id="@+id/tvSnakePlantName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Snake Plant"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/imgSnakePlant"
                        app:layout_constraintTop_toTopOf="@id/imgSnakePlant"
                        app:layout_constraintEnd_toStartOf="@id/btnDeleteSnake" />

                    <TextView
                        android:id="@+id/tvSnakePlantPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 9.90"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/imgSnakePlant"
                        app:layout_constraintTop_toBottomOf="@id/tvSnakePlantName" />

                    <ImageButton
                        android:id="@+id/btnDeleteSnake"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        app:tint="#2ABFBF"
                        android:contentDescription="Delete Snake Plant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton
                        android:id="@+id/btnSnakeMinus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_gray"
                        android:src="@drawable/ic_minus"
                        app:tint="#888888"
                        android:contentDescription="Decrease quantity"
                        app:layout_constraintEnd_toStartOf="@id/tvSnakeQty"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvSnakeQty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="15sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginHorizontal="8dp"
                        app:layout_constraintEnd_toStartOf="@id/btnSnakePlus"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageButton
                        android:id="@+id/btnSnakePlus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_teal"
                        android:src="@drawable/ic_plus"
                        app:tint="#FFFFFF"
                        android:contentDescription="Increase quantity"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Divider above summary -->
    <View
        android:id="@+id/dividerSummary"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtotalLabel"
        android:layout_marginBottom="12dp" />

    <!-- Order Summary -->
    <TextView
        android:id="@+id/tvSubtotalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subtotal"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvDeliveryLabel"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtotalValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ 24.95"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvSubtotalLabel" />

    <TextView
        android:id="@+id/tvDeliveryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Standard delivery"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dividerTotal"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvDeliveryValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ 0.65"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvDeliveryLabel" />

    <View
        android:id="@+id/dividerTotal"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTotalLabel"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvTotalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total amount"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnCheckout"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvTotalValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ 25.6"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/tvTotalLabel" />

    <!-- Checkout Button -->
    <Button
        android:id="@+id/btnCheckout"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Checkout"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2ABFBF"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar" />

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@drawable/bottom_nav_color_selector"
        app:itemTextColor="@drawable/bottom_nav_color_selector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>